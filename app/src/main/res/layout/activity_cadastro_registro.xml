<?xml version="1.0" encoding="utf-8"?>
<!--
    DOCUMENTAÇÃO DE LAYOUT (UI):
    Este arquivo define a interface de usuário para o Cadastro de Registros.
    Utiliza uma hierarquia de LinearLayouts e ScrollView para garantir que o formulário
    seja rolável e responsivo em diferentes tamanhos de tela.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:isScrollContainer="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Card principal que agrupa os campos de entrada -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/txtTitleCadastroRegistro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="@string/title_cadastro_registro"
                    android:textColor="@color/main_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <!--
                    Campo de Data:
                    TextInputLayout fornece o estilo visual (OutlinedBox),
                    enquanto o TextInputEditText é o campo onde o usuário interage.
                -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/hint_data_registro"
                    android:textColor="@color/main_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutDataRegistro"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editDataRegistro"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_edit_text"
                        android:clickable="true"
                        android:focusable="false"
                        android:gravity="center_vertical"
                        android:paddingEnd="16dp"
                        android:textColor="@color/main_text" />
                </com.google.android.material.textfield.TextInputLayout>

                <!--
                    Campo Aves Mortas:
                    Destaque para android:inputType="number", que força o teclado numérico
                    inteiro, facilitando o uso no campo e evitando erros de digitação.
                -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/hint_aves_mortas"
                    android:textColor="@color/main_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutMortas"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editMortas"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_edit_text"
                        android:gravity="center_vertical"
                        android:inputType="number"
                        android:paddingEnd="16dp"
                        android:textColor="@color/main_text" />
                </com.google.android.material.textfield.TextInputLayout>

                <!--
                    Campo Peso Atual:
                    Usa inputType="numberDecimal" para permitir decimais (vírgula/ponto).
                -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Peso Médio (g)"
                    android:textColor="@color/main_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutPesoAtual"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPesoAtual"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_edit_text"
                        android:gravity="center_vertical"
                        android:inputType="numberDecimal"
                        android:paddingEnd="16dp"
                        android:textColor="@color/main_text" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Consumo de Ração -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Consumo de Ração (kg)"
                    android:textColor="@color/main_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutConsumo"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editConsumo"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_edit_text"
                        android:gravity="center_vertical"
                        android:inputType="numberDecimal"
                        android:paddingEnd="16dp"
                        android:textColor="@color/main_text" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Seção de Preços com Insumos -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:text="Informações do Insumo"
                    android:textColor="@color/primary_dark_blue"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:text="Preço p/ kg (R$)"
                            android:textColor="@color/main_text"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/inputLayoutPrecoInsumo"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp"
                            app:hintEnabled="false">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editPrecoInsumo"
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:background="@drawable/bg_edit_text"
                                android:gravity="center_vertical"
                                android:inputType="numberDecimal"
                                android:paddingEnd="12dp"
                                android:textColor="@color/main_text" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Seleção de tipo de insumo via RadioButtons -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.5"
                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <RadioButton
                                android:id="@+id/radioMilho"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Milho"
                                android:textColor="@color/primary_dark_blue"
                                android:textSize="12sp" />
                            <RadioButton
                                android:id="@+id/radioSoja"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Soja"
                                android:textColor="@color/primary_dark_blue"
                                android:textSize="12sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <RadioButton
                                android:id="@+id/radioNucleo"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Núcleo"
                                android:textColor="@color/primary_dark_blue"
                                android:textSize="12sp" />
                            <RadioButton
                                android:id="@+id/radioOutro"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Outro"
                                android:textColor="@color/primary_dark_blue"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Campo de Observações Multi-linha -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/hint_observacoes"
                    android:textColor="@color/main_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutObs"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editObs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_edit_text"
                        android:gravity="top"
                        android:padding="16dp"
                        android:textColor="@color/main_text" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botão de Ação Principal -->
                <Button
                    android:id="@+id/btnSalvarRegistro"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="@string/btn_salvar_registro"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="48dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
