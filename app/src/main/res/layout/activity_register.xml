<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/screen_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="@string/title_registrar"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary_dark_blue" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:textColorHint="@color/secondary_text"
        app:boxStrokeColor="@color/primary_dark_blue"
        app:hintTextColor="@color/primary_dark_blue">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editRegisterEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_email"
            android:inputType="textEmailAddress"
            android:textColor="@color/main_text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputLayoutRegisterSenha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:endIconMode="none"
        app:endIconTint="@color/primary_dark_blue"
        app:boxStrokeColor="@color/primary_dark_blue"
        app:hintTextColor="@color/primary_dark_blue"
        android:textColorHint="@color/secondary_text">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editRegisterSenha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_senha"
            android:inputType="textPassword"
            android:textColor="@color/main_text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputLayoutRegisterConfirmarSenha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:endIconMode="none"
        app:endIconTint="@color/primary_dark_blue"
        app:boxStrokeColor="@color/primary_dark_blue"
        app:hintTextColor="@color/primary_dark_blue"
        android:textColorHint="@color/secondary_text">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editRegisterConfirmarSenha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_confirmar_senha"
            android:inputType="textPassword"
            android:textColor="@color/main_text" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnFinalizarRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="@string/btn_registrar"
        android:backgroundTint="@color/primary_dark_blue"
        android:textColor="@color/white" />

    <ProgressBar
        android:id="@+id/progressBarRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>