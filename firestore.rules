rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar para verificar se o usuário é o dono do dado
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Bloqueia qualquer leitura/escrita global por padrão
    match /{document=**} {
      allow read, write: if false;
    }

    // Proteção da coleção de Avicultores
    match /avicultores/{uid} {
      // O usuário só pode ver e editar seu próprio perfil
      allow get: if isOwner(uid);
      allow create, update: if isOwner(uid);
      // Impede que um usuário liste todos os outros avicultores do sistema
      allow list: if false;

      // Proteção de Lotes
      match /lotes/{loteId} {
        allow read, write: if isOwner(uid);

        // Proteção de Registros
        match /registros/{regId} {
          allow read, write: if isOwner(uid);
        }
      }
    }
  }
}
