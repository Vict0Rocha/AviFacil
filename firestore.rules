rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Função centralizada para administradores
    function isAdmin() {
      return request.auth != null &&
             (request.auth.token.email.lower() == "cristiano@gmail.com" ||
              request.auth.token.email.lower() == "cristianoadm@gmail.com");
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /avicultores/{uid} {
      // Admin tem acesso total à coleção. Usuário tem acesso apenas ao seu UID.
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == uid);

      match /{allChildren=**} {
        allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      }
    }

    // Fallback explícito para garantir que o admin possa listar e editar avicultores
    match /avicultores {
      allow list: if isAdmin();
    }
  }
}
